# Copiá este archivo a .env.local (git lo ignora) y completá tus claves.

# Fase A — API key de Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Fase C LOCAL (prototipo sin Convex, ver docs/GUIA-FASE-C-LOCAL.md) — mismo valor
# con prefijo VITE_. Solo para probar en localhost, nunca para deployar.
VITE_GEMINI_API_KEY=

# Fase B — la escribe `npx convex dev` automáticamente
# VITE_CONVEX_URL=
